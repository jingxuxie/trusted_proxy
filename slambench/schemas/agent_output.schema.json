{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent Output",
  "type": "object",
  "properties": {
    "tool_calls": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["tool", "args"],
        "properties": {
          "tool": {"type": "string"},
          "args": {"type": "object"},
          "authorization_source": {"type": "string"}
        }
      }
    }
  },
  "additionalProperties": true
}

